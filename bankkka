PROMPT = (
    "Ekteki kredi karti ekstresini analiz et. Sadece su JSON formatinda veri dondur: "
    "{'kart_sahibi': 'Isim Soyisim', 'banka': 'Banka Adi', 'donem_borcu': 0.0, "
    "'limit': 0.0, 'taksitler': [{'aciklama': 'Harcama Adi', 'taksit_no': '2/6', 'tutar': 0.0}]}"
)


@dataclass
class ParseResult:
    file_name: str
    data: Dict[str, Any] | None
    error: str | None = None


def parse_float(value: Any) -> float:
    if value is None:
        return 0.0
    if isinstance(value, (int, float)):
        return float(value)
    text = str(value).strip()
    text = text.replace("TL", "").replace("₺", "").replace(" ", "")
    # 1.234,56 -> 1234.56 ; 1,234.56 -> 1234.56
    if "," in text and "." in text:
        if text.rfind(",") > text.rfind("."):
            text = text.replace(".", "").replace(",", ".")
        else:
            text = text.replace(",", "")
    else:
        text = text.replace(",", ".")

    match = re.search(r"-?\d+(?:\.\d+)?", text)
    return float(match.group()) if match else 0.0


def parse_taksit_no(taksit_no: Any) -> Tuple[int, int, int]:
    """2/6 -> (mevcut=2, toplam=6, kalan=4)"""
    if taksit_no is None:
        return 0, 0, 0

    text = str(taksit_no).strip()
    m = re.search(r"(\d+)\s*/\s*(\d+)", text)
    if not m:
        return 0, 0, 0

    mevcut = int(m.group(1))
    toplam = int(m.group(2))
    kalan = max(toplam - mevcut, 0)
    return mevcut, toplam, kalan


def _strip_json_fence(raw_text: str) -> str:
    cleaned = raw_text.strip()
    if cleaned.startswith("```"):
        cleaned = re.sub(r"^```(?:json)?", "", cleaned).strip()
        cleaned = re.sub(r"```$", "", cleaned).strip()
    return cleaned


def normalize_statement_json(payload: Dict[str, Any]) -> Dict[str, Any]:
    out: Dict[str, Any] = {
        "kart_sahibi": str(payload.get("kart_sahibi") or "Bilinmiyor").strip(),
        "banka": str(payload.get("banka") or "Bilinmiyor").strip(),
        "donem_borcu": parse_float(payload.get("donem_borcu")),
        "limit": parse_float(payload.get("limit")),
        "taksitler": [],
    }

    taksitler = payload.get("taksitler")
    if isinstance(taksitler, list):
        for row in taksitler:
            if not isinstance(row, dict):
                continue
            out["taksitler"].append(
                {
                    "aciklama": str(row.get("aciklama") or "-").strip(),
                    "taksit_no": str(row.get("taksit_no") or "0/0").strip(),
                    "tutar": parse_float(row.get("tutar")),
                }
            )

    return out


def call_gemini_for_pdf(
    api_key: str,
    pdf_bytes: bytes,
    model_name: str = "gemini-1.5-flash",
) -> Dict[str, Any]:
    genai.configure(api_key=api_key)
    model = genai.GenerativeModel(model_name)

    response = model.generate_content(
        contents=[
            PROMPT,
            {"mime_type": "application/pdf", "data": pdf_bytes},
        ],
        generation_config={"response_mime_type": "application/json"},
    )

    raw_text = getattr(response, "text", "") or ""
    cleaned = _strip_json_fence(raw_text)

    try:
        payload = json.loads(cleaned)
    except json.JSONDecodeError as exc:
        raise ValueError(f"Model JSON dondurmedi veya JSON bozuk: {exc}") from exc

    if not isinstance(payload, dict):
        raise ValueError("Modelden gelen JSON obje formatinda degil.")

    return normalize_statement_json(payload)


def process_uploaded_files(api_key: str, files: List[Any], model_name: str) -> List[ParseResult]:
    results: List[ParseResult] = []
    progress = st.progress(0, text="PDF analizleri baslatiliyor...")

    for idx, file in enumerate(files, start=1):
        try:
            data = call_gemini_for_pdf(
                api_key=api_key,
                pdf_bytes=file.getvalue(),
                model_name=model_name,
            )
            results.append(ParseResult(file_name=file.name, data=data, error=None))
        except Exception as exc:
            results.append(ParseResult(file_name=file.name, data=None, error=str(exc)))

        progress.progress(
            int((idx / len(files)) * 100),
            text=f"{idx}/{len(files)} dosya analiz edildi",
        )

    return results


def build_dataframes(results: List[ParseResult]) -> Tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    card_rows: List[Dict[str, Any]] = []
    installment_rows: List[Dict[str, Any]] = []
    error_rows: List[Dict[str, Any]] = []

    for item in results:
        if item.error:
            error_rows.append({"Dosya": item.file_name, "Hata": item.error})
            continue

        data = item.data or {}
        owner = data.get("kart_sahibi", "Bilinmiyor")
        bank = data.get("banka", "Bilinmiyor")
        debt = parse_float(data.get("donem_borcu"))
        limit = parse_float(data.get("limit"))

        card_rows.append(
            {
                "Dosya": item.file_name,
                "kart_sahibi": owner,
                "banka": bank,
                "donem_borcu": debt,
                "limit": limit,
                "kullanilabilir_limit": max(limit - debt, 0.0),
            }
        )

        for taksit in data.get("taksitler", []):
            mevcut, toplam, kalan = parse_taksit_no(taksit.get("taksit_no"))
            aylik_tutar = parse_float(taksit.get("tutar"))

            installment_rows.append(
                {
                    "Dosya": item.file_name,
                    "kart_sahibi": owner,
                    "banka": bank,
                    "aciklama": taksit.get("aciklama", "-"),
                    "taksit_no": taksit.get("taksit_no", "0/0"),
                    "Mevcut Taksit": mevcut,
                    "Toplam Taksit": toplam,
                    "Kalan Taksit Sayisi": kalan,
                    "Aylik Tutar": aylik_tutar,
                    "Kalan Toplam Borc": kalan * aylik_tutar,
                }
            )

    cards_df = pd.DataFrame(card_rows)
    installments_df = pd.DataFrame(installment_rows)
    errors_df = pd.DataFrame(error_rows)
    return cards_df, installments_df, errors_df


def format_currency_columns(df: pd.DataFrame, columns: List[str]) -> pd.DataFrame:
    out = df.copy()
    for col in columns:
        if col in out.columns:
            out[col] = out[col].map(lambda x: f"₺{float(x):,.2f}".replace(",", "X").replace(".", ",").replace("X", "."))
    return out


