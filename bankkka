st.markdown(page_bg_css, unsafe_allow_html=True)

st.title("💳 Liquid Kredi Kartı & Taksit Paneli")

# ==========================================
# 2. YAN PANEL (API KEY VE DOSYA YÜKLEME)
# ==========================================
with st.sidebar:
    st.header("⚙️ Ayarlar")
    # Kodun patlamaması için API Key'i arayüzden alıyoruz (Netlify'da kolaylık sağlar)
    api_key = st.text_input("Gemini API Key'inizi Girin", type="password")
    st.divider()
    uploaded_files = st.file_uploader("Ekstreleri Yükle (PDF)", type="pdf", accept_multiple_files=True)

# ==========================================
# 3. YARDIMCI FONKSİYONLAR VE PROMPT
# ==========================================
def parse_installment(taksit_str):
    try:
        current, total = map(int, str(taksit_str).split('/'))
        return total - current
    except:
        return 0

PROMPT = """
Ekteki kredi kartı ekstresini analiz et. Sadece şu JSON formatında veri döndür. Asla başka bir metin yazma:
{
  "kart_sahibi": "İsim Soyisim",
  "banka": "Banka Adı",
  "donem_borcu": 0.0,
  "limit": 0.0,
  "taksitler": [
    {"aciklama": "Harcama Adı", "taksit_no": "2/6", "tutar": 0.0}
  ]
}
"""

# ==========================================
# 4. ANA İŞLEYİŞ VE GEMINI BAĞLANTISI
# ==========================================
if not api_key:
    st.warning("👈 Lütfen sol menüden Gemini API Key'inizi girin.")
else:
    genai.configure(api_key=api_key)
    # response_mime_type bizi JSON formatının dışına çıkmaktan kurtarıyor
    model = genai.GenerativeModel('gemini-1.5-flash', generation_config={"response_mime_type": "application/json"})

    if uploaded_files:
        if st.button("🚀 Ekstreleri Analiz Et"):
            all_data = []
            
            with st.spinner("Yapay Zeka PDF'leri okuyor, lütfen bekleyin..."):
                for file in uploaded_files:
                    try:
                        # PDF'i belleğe alıp Gemini'ye blob olarak gönderiyoruz
                        blob = {'mime_type': 'application/pdf', 'data': file.getvalue()}
                        response = model.generate_content([PROMPT, blob])
                        
                        # JSON'ı parse et
                        data = json.loads(response.text)
                        all_data.append(data)
                    except Exception as e:
                        st.error(f"{file.name} işlenirken hata oluştu: {e}")

            if all_data:
                df_main = pd.DataFrame(all_data)
                
                # --- ÜST PANEL METRİKLERİ ---
                total_debt = df_main['donem_borcu'].sum()
                total_limit = df_main['limit'].sum()
                
                col1, col2, col3 = st.columns(3)
                col1.metric("Toplam Dönem Borcu", f"{total_debt:,.2f} ₺")
                col2.metric("Toplam Kart Limiti", f"{total_limit:,.2f} ₺")
                col3.metric("Kalan Boş Limit", f"{(total_limit - total_debt):,.2f} ₺")
                
                st.divider()

                # --- KULLANICI BAZLI KARTLAR ---
                sahipler = df_main['kart_sahibi'].unique()
                
                for sahip in sahipler:
                    st.subheader(f"👤 Kullanıcı: {sahip}")
                    user_data = df_main[df_main['kart_sahibi'] == sahip]
                    
                    # Kullanıcının Kart Özeti
                    st.dataframe(user_data[['banka', 'donem_borcu', 'limit']], use_container_width=True, hide_index=True)
                    
                    # Kullanıcının Taksit Hesaplamaları
                    taksit_listesi = []
                    for _, row in user_data.iterrows():
                        for t in row.get('taksitler', []):
                            kalan_taksit = parse_installment(t.get('taksit_no', '0/0'))
                            aylik_tutar = float(t.get('tutar', 0))
                            
                            taksit_listesi.append({
                                "Banka": row['banka'],
                                "Harcama": t.get('aciklama', ''),
                                "Durum": t.get('taksit_no', ''),
                                "Kalan Ay": kalan_taksit,
                                "Aylık Taksit (₺)": aylik_tutar,
                                "Gelecek Toplam Borç (₺)": kalan_taksit * aylik_tutar
                            })
                    
                    if taksit_listesi:
                        st.write("📅 **Aktif Taksit Durumu**")
                        df_taksit = pd.DataFrame(taksit_listesi)
                        st.dataframe(df_taksit, use_container_width=True, hide_index=True)
                    else:
                        st.info("Bu kullanıcıya ait aktif taksit bulunamadı.")
                    
                    st.write("---")
