import streamlit as st
import google.generativeai as genai
import pandas as pd
import json

# ==========================================
# 1. SAYFA VE TASARIM AYARLARI (LIQUID GLASS)
# ==========================================
st.set_page_config(page_title="Finansal Dashboard", layout="wide", page_icon="💳")

# Glassmorphism (Cam efekti) ve Arka Plan CSS'i
page_bg_css = """
